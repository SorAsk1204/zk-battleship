# artifacts/ 提交 git(D5),manifest.json 记录每个文件的 sha256:
# 必须保证 clone 后字节逐一还原,任何 eol 转换都会让 manifest 哈希对不上
# (本机 autocrlf=true 时 verification_key.json/manifest.json 会被转 CRLF)。
# wasm/zkey 虽会被 git 自动识别为二进制,这里一并显式钉死,不赌启发式。
packages/circuits/artifacts/** -text
# snarkjs 导出的 verifier 同理钉死 LF:幂等 re-export 验证法(重导出后 git diff 应为空)
# 依赖字节级一致,autocrlf=true 的 clone 若被转 CRLF,重导出必出假 diff。
packages/contracts/src/verifiers/*.sol eol=lf
